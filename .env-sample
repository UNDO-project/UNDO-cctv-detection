# ============================================================
# CCTV Detection Configuration
# ============================================================
#
# Copy this file to .env and customize for your local environment.
# All environment variables use the CCTV_ prefix.
# Nested settings use double underscore (__) delimiter.
#
# Example: CCTV_TRAINING__BATCH_SIZE=8
#

# ============================================================
# Logging
# ============================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
CCTV_LOG_LEVEL=INFO


# ============================================================
# Model Weights
# ============================================================

# Path to YOLOv8 model weights (relative to project root or absolute)
# Default: samples/best.pt
CCTV_MODELS__YOLO_WEIGHTS=samples/best.pt

# Path to Faster R-CNN model weights
# Default: samples/fasterrcnn_best.pt
# CCTV_MODELS__FASTER_RCNN_WEIGHTS=samples/fasterrcnn_best.pt

# Path to DETR model weights
# Default: samples/detr_best.pt
# CCTV_MODELS__DETR_WEIGHTS=samples/detr_best.pt


# ============================================================
# Training Configuration
# ============================================================

# Training set ratio (0.1-0.9)
# Default: 0.7
CCTV_TRAINING__TRAIN_RATIO=0.7

# Validation set ratio (0.1-0.9)
# Default: 0.3
CCTV_TRAINING__VAL_RATIO=0.3

# Training batch size (1-128)
# Default: 4
CCTV_TRAINING__BATCH_SIZE=4

# Number of training epochs (1-1000)
# Default: 20
CCTV_TRAINING__EPOCHS=20

# Initial learning rate (0-1)
# Default: 0.005
CCTV_TRAINING__LEARNING_RATE=0.005

# Input image size in pixels (320-1280)
# Default: 640
CCTV_TRAINING__IMAGE_SIZE=640


# ============================================================
# Web Scraper Configuration
# ============================================================

# Path to CSV file with camera locations
# Default: datasets/cctv-aware-jyvaskyla.csv
CCTV_SCRAPER__CSV_FILE=datasets/cctv-aware-jyvaskyla.csv

# Output directory for screenshots
# Default: datasets/screenshots
CCTV_SCRAPER__OUTPUT_DIR=datasets/screenshots

# Browser page load timeout in milliseconds (1000-60000)
# Default: 20000
CCTV_SCRAPER__BROWSER_TIMEOUT_MS=20000

# Cookie dialog timeout in milliseconds (1000-30000)
# Default: 5000
CCTV_SCRAPER__COOKIE_DIALOG_TIMEOUT_MS=5000

# Page settle timeout in milliseconds (1000-30000)
# Default: 5000
CCTV_SCRAPER__PAGE_SETTLE_TIMEOUT_MS=5000

# Run browser in headless mode (true/false)
# Default: true
CCTV_SCRAPER__HEADLESS=true

# English cookie rejection button text
# Default: "Reject all"
CCTV_SCRAPER__REJECT_ALL_TEXT="Reject all"

# Greek cookie rejection button text
# Default: "Απόρριψη όλων"
CCTV_SCRAPER__REJECT_ALL_TEXT_GR="Απόρριψη όλων"


# ============================================================
# Advanced: Path Overrides
# ============================================================

# These paths are automatically computed from PROJECT_ROOT.
# Only override if you need custom directory structure.

# Override project root directory
# Default: auto-detected from src/config.py location
# CCTV_PATHS__PROJECT_ROOT=/custom/path/to/project

# Note: Overriding PROJECT_ROOT will affect all derived paths:
# - datasets_dir (project_root/datasets)
# - samples_dir (project_root/samples)
# - images_dir (datasets_dir/images)
# - labels_dir (datasets_dir/labels)
# - ultralytics_dir (datasets_dir/ultralytics)
# - data_config (project_root/data.yaml)


# ============================================================
# Usage Examples
# ============================================================

# Example 1: Use custom model weights
# CCTV_MODELS__YOLO_WEIGHTS=/path/to/custom/model.pt

# Example 2: Train with larger batch size
# CCTV_TRAINING__BATCH_SIZE=16

# Example 3: Use DEBUG logging
# CCTV_LOG_LEVEL=DEBUG

# Example 4: Run scraper in non-headless mode (show browser)
# CCTV_SCRAPER__HEADLESS=false

# Example 5: Custom dataset location
# CCTV_PATHS__PROJECT_ROOT=/mnt/external/cctv_detection